# ---------------------------------------------------------------------------
# DEFEND-US — environment configuration
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.
# ---------------------------------------------------------------------------

# --- Anthropic (server-side only — never exposed to the browser) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Firebase (client config — safe to expose; these are public by design) ---
# From Firebase console → Project settings → Your apps → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Access control ---
# Only this Google account may sign in and read/write data.
# (Also enforce this in Firestore security rules — see firestore.rules.)
NEXT_PUBLIC_ALLOWED_EMAIL=davidhamiltonsg@gmail.com
